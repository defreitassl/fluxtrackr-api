generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  income
  expense
}

enum TransactionSource {
  app
  telegram
}

enum CategoryType {
  income
  expense
  both
}

enum PaymentMethod {
  pix
  debit
  credit
  cash
  transfer
  boleto
}

enum AccountType {
  checking
  savings
  wallet
  cash
  investment
  other
}

enum CreditCardInvoiceStatus {
  open
  closed
  paid
  overdue
  canceled
}

enum InstallmentStatus {
  pending
  paid
  canceled
}

enum RecurrenceType {
  once
  monthly
  yearly
  semiannual
  custom
}

enum FinancialEventStatus {
  planned
  confirmed
  postponed
  canceled
  realized
}

enum FixedOccurrenceType {
  expense
  income
}

enum FixedOccurrenceStatus {
  pending
  realized
  canceled
}

enum SubscriptionChargeStatus {
  pending
  realized
  canceled
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  categories          Category[]
  transactions        Transaction[]
  fixedExpenses       FixedExpense[]
  fixedIncomes        FixedIncome[]
  accounts            Account[]
  creditCards         CreditCard[]
  invoices            CreditCardInvoice[]
  installments        Installment[]
  creditCardPurchases CreditCardPurchase[]
  events              FinancialEvent[]
  subscriptions       Subscription[]
  subscriptionCharges SubscriptionCharge[]
  fixedOccurrences    FixedOccurrence[]
  accountTransfers    AccountTransfer[]
  balanceAdjustments  AccountBalanceAdjustment[]
  categoryBudgets     CategoryBudget[]
}

model Category {
  id        String       @id @default(uuid())
  userId    String
  name      String
  type      CategoryType
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     Transaction[]
  installments     Installment[]
  purchases        CreditCardPurchase[]
  events           FinancialEvent[]
  subscriptions    Subscription[]
  subscriptionCharges SubscriptionCharge[]
  fixedExpenses    FixedExpense[]
  fixedIncomes     FixedIncome[]
  fixedOccurrences FixedOccurrence[]
  budgets          CategoryBudget[]

  @@unique([userId, name])
  @@index([userId])
}

model Transaction {
  id            String            @id @default(uuid())
  userId        String
  type          TransactionType
  amount        Decimal           @db.Decimal(12, 2)
  description   String
  categoryId    String?
  accountId     String?
  paymentMethod PaymentMethod?
  occurredAt    DateTime
  source        TransactionSource
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user                    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  category                Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  account                 Account?           @relation(fields: [accountId], references: [id], onDelete: SetNull)
  confirmedFinancialEvent FinancialEvent?    @relation("ConfirmedFinancialEvent")
  paidCreditCardInvoice   CreditCardInvoice? @relation("InvoicePaymentTransaction")
  realizedFixedOccurrence FixedOccurrence?   @relation("FixedOccurrenceTransaction")
  realizedSubscriptionCharge SubscriptionCharge? @relation("SubscriptionChargeTransaction")

  @@index([userId, occurredAt])
  @@index([categoryId])
  @@index([accountId])
}

model CategoryBudget {
  id                String   @id @default(uuid())
  userId            String
  categoryId        String
  year              Int
  month             Int
  limitAmount       Decimal  @db.Decimal(12, 2)
  warningPercentage Int      @default(80)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId, year, month])
  @@index([userId, year, month])
  @@index([categoryId, year, month])
}

model FixedExpense {
  id            String         @id @default(uuid())
  userId        String
  name          String
  amount        Decimal        @db.Decimal(12, 2)
  dueDay        Int?
  categoryId    String?
  accountId     String?
  paymentMethod PaymentMethod?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  account     Account?          @relation(fields: [accountId], references: [id], onDelete: SetNull)
  occurrences FixedOccurrence[]

  @@index([userId])
  @@index([categoryId])
  @@index([accountId])
}

model Account {
  id             String      @id @default(uuid())
  userId         String
  name           String
  bank           String?
  type           AccountType
  color          String?
  icon           String?
  initialBalance Decimal     @db.Decimal(12, 2)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions       Transaction[]
  creditCards        CreditCard[]
  invoices           CreditCardInvoice[]
  events             FinancialEvent[]
  subscriptions      Subscription[]
  subscriptionCharges SubscriptionCharge[]
  fixedExpenses      FixedExpense[]
  fixedIncomes       FixedIncome[]
  fixedOccurrences   FixedOccurrence[]
  outgoingTransfers  AccountTransfer[]          @relation("OutgoingTransfers")
  incomingTransfers  AccountTransfer[]          @relation("IncomingTransfers")
  balanceAdjustments AccountBalanceAdjustment[]

  @@unique([userId, name])
  @@index([userId])
}

model CreditCard {
  id             String   @id @default(uuid())
  userId         String
  accountId      String?
  name           String
  bankName       String?
  brand          String?
  lastFourDigits String?
  limitAmount    Decimal  @db.Decimal(12, 2)
  closingDay     Int?
  dueDay         Int
  color          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  account       Account?             @relation(fields: [accountId], references: [id], onDelete: SetNull)
  invoices      CreditCardInvoice[]
  installments  Installment[]
  purchases     CreditCardPurchase[]
  events        FinancialEvent[]
  subscriptions Subscription[]
  subscriptionCharges SubscriptionCharge[]

  @@unique([userId, name])
  @@index([userId])
  @@index([accountId])
}

model CreditCardInvoice {
  id                String                  @id @default(uuid())
  userId            String
  creditCardId      String
  accountId         String?
  month             Int
  year              Int
  dueDate           DateTime
  closingDate       DateTime?
  status            CreditCardInvoiceStatus @default(open)
  paidAt            DateTime?
  paidAmount        Decimal?                @db.Decimal(12, 2)
  paidTransactionId String?                 @unique
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditCard      CreditCard    @relation(fields: [creditCardId], references: [id], onDelete: Cascade)
  account         Account?      @relation(fields: [accountId], references: [id], onDelete: SetNull)
  installments    Installment[]
  paidTransaction Transaction?  @relation("InvoicePaymentTransaction", fields: [paidTransactionId], references: [id], onDelete: SetNull)

  @@unique([creditCardId, year, month])
  @@index([userId, year, month])
  @@index([creditCardId])
  @@index([accountId])
}

model Installment {
  id                  String            @id @default(uuid())
  userId              String
  creditCardId        String
  invoiceId           String?
  purchaseId          String?
  categoryId          String?
  description         String
  totalPurchaseAmount Decimal           @db.Decimal(12, 2)
  installmentAmount   Decimal           @db.Decimal(12, 2)
  installmentNumber   Int
  installmentCount    Int
  purchaseDate        DateTime
  dueDate             DateTime
  status              InstallmentStatus @default(pending)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditCard CreditCard          @relation(fields: [creditCardId], references: [id], onDelete: Cascade)
  invoice    CreditCardInvoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  purchase   CreditCardPurchase? @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  category   Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, dueDate])
  @@index([creditCardId])
  @@index([invoiceId])
  @@index([purchaseId])
  @@index([categoryId])
}

model CreditCardPurchase {
  id               String   @id @default(uuid())
  userId           String
  creditCardId     String
  categoryId       String?
  description      String
  totalAmount      Decimal  @db.Decimal(12, 2)
  purchaseDate     DateTime
  installmentCount Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user                    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditCard              CreditCard      @relation(fields: [creditCardId], references: [id], onDelete: Cascade)
  category                Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  installments            Installment[]
  confirmedFinancialEvent FinancialEvent? @relation("ConfirmedCreditCardPurchase")
  realizedSubscriptionCharge SubscriptionCharge? @relation("SubscriptionChargeCreditCardPurchase")

  @@index([userId, purchaseDate])
  @@index([creditCardId])
  @@index([categoryId])
}

model FinancialEvent {
  id                            String               @id @default(uuid())
  userId                        String
  type                          TransactionType
  name                          String
  expectedAmount                Decimal              @db.Decimal(12, 2)
  date                          DateTime
  categoryId                    String?
  accountId                     String?
  creditCardId                  String?
  paymentMethod                 PaymentMethod?
  recurrence                    RecurrenceType       @default(once)
  installmentCount              Int                  @default(1)
  status                        FinancialEventStatus @default(planned)
  notes                         String?
  confirmedTransactionId        String?              @unique
  confirmedCreditCardPurchaseId String?              @unique
  createdAt                     DateTime             @default(now())
  updatedAt                     DateTime             @updatedAt

  user                        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  category                    Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  account                     Account?            @relation(fields: [accountId], references: [id], onDelete: SetNull)
  creditCard                  CreditCard?         @relation(fields: [creditCardId], references: [id], onDelete: SetNull)
  confirmedTransaction        Transaction?        @relation("ConfirmedFinancialEvent", fields: [confirmedTransactionId], references: [id], onDelete: SetNull)
  confirmedCreditCardPurchase CreditCardPurchase? @relation("ConfirmedCreditCardPurchase", fields: [confirmedCreditCardPurchaseId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([categoryId])
  @@index([accountId])
  @@index([creditCardId])
}

model Subscription {
  id             String         @id @default(uuid())
  userId         String
  name           String
  amount         Decimal        @db.Decimal(12, 2)
  recurrenceAnchorDate DateTime
  nextChargeDate DateTime
  recurrence     RecurrenceType
  categoryId     String?
  accountId      String?
  creditCardId   String?
  paymentMethod  PaymentMethod?
  autoRenew      Boolean        @default(true)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  account    Account?    @relation(fields: [accountId], references: [id], onDelete: SetNull)
  creditCard CreditCard? @relation(fields: [creditCardId], references: [id], onDelete: SetNull)
  charges    SubscriptionCharge[]

  @@unique([userId, name])
  @@index([userId, recurrenceAnchorDate])
  @@index([userId, nextChargeDate])
  @@index([categoryId])
  @@index([accountId])
  @@index([creditCardId])
}

model SubscriptionCharge {
  id                           String                   @id @default(uuid())
  userId                       String
  subscriptionId               String
  status                       SubscriptionChargeStatus @default(pending)
  name                         String
  amount                       Decimal                  @db.Decimal(12, 2)
  chargeDate                   DateTime
  year                         Int
  month                        Int
  categoryId                   String?
  accountId                    String?
  creditCardId                 String?
  paymentMethod                PaymentMethod?
  realizedTransactionId        String?                  @unique
  realizedCreditCardPurchaseId String?                  @unique
  realizedAt                   DateTime?
  canceledAt                   DateTime?
  createdAt                    DateTime                 @default(now())
  updatedAt                    DateTime                 @updatedAt

  user                         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription                 Subscription             @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  category                     Category?                @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  account                      Account?                 @relation(fields: [accountId], references: [id], onDelete: SetNull)
  creditCard                   CreditCard?              @relation(fields: [creditCardId], references: [id], onDelete: SetNull)
  realizedTransaction          Transaction?             @relation("SubscriptionChargeTransaction", fields: [realizedTransactionId], references: [id], onDelete: SetNull)
  realizedCreditCardPurchase   CreditCardPurchase?      @relation("SubscriptionChargeCreditCardPurchase", fields: [realizedCreditCardPurchaseId], references: [id], onDelete: SetNull)

  @@unique([subscriptionId, chargeDate])
  @@index([userId, chargeDate])
  @@index([userId, status, chargeDate])
  @@index([subscriptionId])
  @@index([accountId])
  @@index([creditCardId])
}

model FixedIncome {
  id            String         @id @default(uuid())
  userId        String
  name          String
  amount        Decimal        @db.Decimal(12, 2)
  receiveDay    Int?
  categoryId    String?
  accountId     String?
  paymentMethod PaymentMethod?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  account     Account?          @relation(fields: [accountId], references: [id], onDelete: SetNull)
  occurrences FixedOccurrence[]

  @@index([userId])
  @@index([categoryId])
  @@index([accountId])
}

model FixedOccurrence {
  id                    String                @id @default(uuid())
  userId                String
  type                  FixedOccurrenceType
  status                FixedOccurrenceStatus @default(pending)
  fixedExpenseId        String?
  fixedIncomeId         String?
  name                  String
  amount                Decimal               @db.Decimal(12, 2)
  occurrenceDate        DateTime
  year                  Int
  month                 Int
  categoryId            String?
  accountId             String?
  paymentMethod         PaymentMethod?
  realizedTransactionId String?               @unique
  realizedAt            DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  fixedExpense        FixedExpense? @relation(fields: [fixedExpenseId], references: [id], onDelete: SetNull)
  fixedIncome         FixedIncome?  @relation(fields: [fixedIncomeId], references: [id], onDelete: SetNull)
  category            Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  account             Account?      @relation(fields: [accountId], references: [id], onDelete: SetNull)
  realizedTransaction Transaction?  @relation("FixedOccurrenceTransaction", fields: [realizedTransactionId], references: [id], onDelete: SetNull)

  @@unique([fixedExpenseId, year, month])
  @@unique([fixedIncomeId, year, month])
  @@index([userId, occurrenceDate])
  @@index([userId, status, occurrenceDate])
  @@index([fixedExpenseId])
  @@index([fixedIncomeId])
  @@index([categoryId])
  @@index([accountId])
}

model AccountTransfer {
  id                   String   @id @default(uuid())
  userId               String
  sourceAccountId      String
  destinationAccountId String
  amount               Decimal  @db.Decimal(12, 2)
  description          String?
  occurredAt           DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceAccount      Account @relation("OutgoingTransfers", fields: [sourceAccountId], references: [id])
  destinationAccount Account @relation("IncomingTransfers", fields: [destinationAccountId], references: [id])

  @@index([userId, occurredAt])
  @@index([sourceAccountId, occurredAt])
  @@index([destinationAccountId, occurredAt])
}

model AccountBalanceAdjustment {
  id              String   @id @default(uuid())
  userId          String
  accountId       String
  previousBalance Decimal  @db.Decimal(12, 2)
  newBalance      Decimal  @db.Decimal(12, 2)
  difference      Decimal  @db.Decimal(12, 2)
  reason          String?
  occurredAt      DateTime
  createdAt       DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id])

  @@index([userId, occurredAt])
  @@index([accountId, occurredAt])
}
