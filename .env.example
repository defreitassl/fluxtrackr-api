POSTGRES_DB=fluxtrackr_dev
POSTGRES_USER=fluxtrackr
POSTGRES_PASSWORD=fluxtrackr
POSTGRES_PORT=5433
DATABASE_URL=postgresql://fluxtrackr:fluxtrackr@localhost:5433/fluxtrackr_dev?schema=public
# PostgreSQL connection pool. Use the defaults for one API replica.
DATABASE_POOL_MAX=5
DATABASE_POOL_IDLE_TIMEOUT_MS=10000
DATABASE_CONNECTION_TIMEOUT_MS=5000
# Set to 15 or 30 only while collecting process metrics; 0 disables the timer.
RESOURCE_METRICS_INTERVAL_MINUTES=0
JWT_SECRET=replace-with-a-long-random-secret
# Optional. Comma-separated browser origins allowed to call the API.
WEB_ORIGIN=http://localhost:3000
# Required only when running `npm run prisma:seed` to bootstrap the first user.
BOOTSTRAP_USER_NAME=FluxTrackr Local
BOOTSTRAP_USER_EMAIL=local@fluxtrackr.test
BOOTSTRAP_USER_PASSWORD=change-this-local-password
# Local development only. Never enable fixtures in production.
ALLOW_DEV_FIXTURES=false
DEV_FIXTURE_POPULATED_EMAIL=complete@fluxtrackr.test
DEV_FIXTURE_EMPTY_EMAIL=empty@fluxtrackr.test
DEV_FIXTURE_PASSWORD=
DEV_FIXTURE_USER_NAME_PREFIX=FluxTrackr Dev
